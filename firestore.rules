rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: email (string), role (string: admin|client), displayName (string)
    //
    // Collection: vehicles
    // Fields: make (string), model (string), year (int), price (number), status (string: AVAILABLE|RENTED|OWNED)
    //
    // Collection: contracts
    // Fields: vehicleId (string), userId (string), totalPaid (number), totalBalance (number), status (string)
    //
    // Collection: payments
    // Fields: contractId (string), userId (string), amount (number), stripeId (string), timestamp (timestamp)
    //
    // Collection: certificates
    // Fields: contractId (string), userId (string), certificateId (string), ownerName (string), issuedAt (timestamp)
    //
    // Collection: notifications
    // Fields: type (string), contractId (string), userId (string), userEmail (string), message (string), timestamp (timestamp), read (bool)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "haylenik@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string &&
             data.role in ['admin', 'client'];
    }

    function isValidVehicle(data) {
      return data.keys().hasAll(['make', 'model', 'year', 'price', 'status']) &&
             data.make is string && data.model is string &&
             data.year is int && data.price is number &&
             data.status in ['AVAILABLE', 'RENTED', 'OWNED'];
    }

    function isValidContract(data) {
      return data.keys().hasAll(['vehicleId', 'userId', 'totalPaid', 'totalBalance', 'status']) &&
             data.vehicleId is string && data.userId is string &&
             data.totalPaid is number && data.totalBalance is number &&
             data.status in ['ACTIVE', 'DELINQUENT', 'DEFAULTED', 'COMPLETED'];
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['contractId', 'userId', 'amount', 'stripeId', 'timestamp']) &&
             data.contractId is string && data.userId is string &&
             data.amount is number && data.stripeId is string;
    }

    function isValidCertificate(data) {
      return data.keys().hasAll(['contractId', 'userId', 'certificateId', 'ownerName', 'issuedAt']) &&
             data.contractId is string && data.userId is string &&
             data.certificateId is string && data.ownerName is string;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['type', 'contractId', 'message', 'timestamp', 'read']) &&
             data.type in ['PAYMENT_FAILED', 'CONTRACT_DELINQUENT'] &&
             data.contractId is string && data.message is string &&
             data.read is bool;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == 'client' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin());
    }

    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidVehicle(request.resource.data);
    }

    match /contracts/{contractId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidContract(request.resource.data) && 
                    (request.auth.uid == request.resource.data.userId || isAdmin());
      allow update: if isAuthenticated() && isValidContract(request.resource.data) && 
                    (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidPayment(request.resource.data) && 
                    (request.auth.uid == request.resource.data.userId || isAdmin());
    }

    match /certificates/{certificateId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidCertificate(request.resource.data) && 
                    (request.auth.uid == request.resource.data.userId || isAdmin());
    }

    match /reconciliation_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read, write: if isAdmin();
      // Allow users to trigger notifications (e.g. on failed payment)
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
    }
  }
}
